{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "Name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "Description": {
            "type": "string",
            "minLength": 1
        },
        "Type": {
            "type": "string",
            "minLength": 1
        },
        "RegionInt": {
            "oneOf": [
                {
                    "type": "integer",
                    "minimum": 0
                },
                {
                    "type": "object",
                    "properties": {
                        "U": { "type": "integer" },
                        "E": { "type": "integer" },
                        "J": { "type": "integer" },
                        "C": { "type": "integer" },
                        "B": { "type": "integer" }
                    },
                    "additionalProperties": false
                }
            ]
        },
        "Category": {
            "type": "string",
            "enum": [
                "bool",
                "flags",
                "ascii",
                "sjis",
                "text",
                "gfx",
                "tilemap",
                "palette",
                "oam_frame",
                "bg_blocks",
                "bg_map",
                "pcm",
                "thumb",
                "arm"
            ]
        },
        "Compression": {
            "type": "string",
            "enum": ["rle", "lz"]
        },
        "Location": {
            "type": "string",
            "pattern": "[A-Za-z0-9_]+\\.[A-Za-z]+:[0-9]+$"
        },
        "Var": {
            "type": "object",
            "properties": {
                "desc": {
                    "$ref": "#/definitions/Description"
                },
                "type": {
                    "$ref": "#/definitions/Type"
                },
                "count": {
                    "$ref": "#/definitions/RegionInt"
                },
                "cat": {
                    "$ref": "#/definitions/Category"
                },
                "comp": {
                    "$ref": "#/definitions/Compression"
                },
                "enum": {
                    "$ref": "#/definitions/Name"
                }
            },
            "required": ["type"],
            "additionalProperties": false
        },
        "NamedVar": {
            "type": "object",
            "properties": {
                "name": {
                    "$ref": "#/definitions/Name"
                },
                "desc": {
                    "$ref": "#/definitions/Description"
                },
                "type": {
                    "$ref": "#/definitions/Type"
                },
                "count": {
                    "$ref": "#/definitions/RegionInt"
                },
                "cat": {
                    "$ref": "#/definitions/Category"
                },
                "comp": {
                    "$ref": "#/definitions/Compression"
                },
                "enum": {
                    "$ref": "#/definitions/Name"
                }
            },
            "required": ["name", "type"],
            "additionalProperties": false
        }
    }
}
