{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "name": {
                "$ref": "urn:definitions#/definitions/Name"
            },
            "desc": {
                "$ref": "urn:definitions#/definitions/Description"
            },
            "size": {
                "type": "integer"
            },
            "vars": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "$ref": "urn:definitions#/definitions/Name"
                        },
                        "desc": {
                            "$ref": "urn:definitions#/definitions/Description"
                        },
                        "type": {
                            "$ref": "urn:definitions#/definitions/Type"
                        },
                        "count": {
                            "$ref": "urn:definitions#/definitions/RegionInt"
                        },
                        "offset": {
                            "$ref": "urn:definitions#/definitions/RegionInt"
                        },
                        "bits": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "cat": {
                            "$ref": "urn:definitions#/definitions/Category"
                        },
                        "comp": {
                            "$ref": "urn:definitions#/definitions/Compression"
                        },
                        "enum": {
                            "$ref": "urn:definitions#/definitions/Name"
                        }
                    },
                    "required": ["name", "type", "offset"],
                    "additionalProperties": false
                },
                "minItems": 1
            },
            "loc": {
                "$ref": "urn:definitions#/definitions/Location"
            }
        },
        "required": ["name", "size", "vars", "loc"],
        "additionalProperties": false
    }
}
